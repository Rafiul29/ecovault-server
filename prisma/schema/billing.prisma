model Payment {
  id            String        @id @default(cuid())
  amount        Float
  status        PaymentStatus @default(PENDING)
  transactionId String?       @unique
  paymentMethod String? // sslcommerz, stripe, bKash

  user   User   @relation(fields: [userId], references: [id])
  userId String

  paymentGatewayData Json? // RAW response from gateway

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]

  @@index([userId])
  @@index([status])
  @@map("payment")
}

model SubscriptionPlan {
  id            String           @id @default(cuid())
  name          String           @unique
  description   String?
  tier          SubscriptionTier
  price         Float
  
  durationDays  Int              @default(30) // 30-day plan etc.
  features      String[]         @default([]) // e.g. ["Browse all public ideas", "Submit up to 2 ideas/month", ...]
  order         Int              @default(0)  // To order the plans in the UI
  isPopular     Boolean          @default(false)
  buttonText    String?          @default("Get Started") 
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  subscriptions Subscription[]

  @@index([isActive])
  @@index([price])
  @@index([order])
  @@map("subscription_plan")
}

model Subscription {
  id     String           @id @default(cuid())
  tier   SubscriptionTier @default(FREE)
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String           @unique

  startDate          DateTime          @default(now())
  endDate            DateTime?
  isActive           Boolean           @default(true)
  autoRenew          Boolean           @default(true)
  subscriptionPlanId String?
  subscriptionPlan   SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  paymentId          String?
  payment            Payment?          @relation(fields: [paymentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([subscriptionPlanId])
  @@index([paymentId])
  @@map("subscription")
}
