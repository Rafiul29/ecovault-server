model Notification {
  id      String           @id @default(cuid())
  type    NotificationType
  title   String
  message String
  isRead  Boolean          @default(false)
  data    Json? // { link: "/ideas/123", icon: "approval" }

  user   User   @relation(fields: [userId], references: [id])
  userId String

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notification")
}

model AuditLog {
  id         String @id @default(cuid())
  action     String // CREATE, UPDATE, DELETE, etc.
  resource   String // Idea, User, Comment
  resourceId String

  actor   User   @relation("actor", fields: [actorId], references: [id])
  actorId String

  previousState Json?
  newState      Json?
  ipAddress     String?
  userAgent     String?

  createdAt DateTime @default(now())

  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_log")
}

model SearchHistory {
  id           String @id @default(cuid())
  query        String
  resultsCount Int

  user   User   @relation(fields: [userId], references: [id])
  userId String

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("search_historie")
}

model Newsletter {
  id           String  @id @default(cuid())
  email        String  @unique
  isSubscribed Boolean @default(true)

  createdAt DateTime @default(now())

  @@map("newsletter")
}

model Achievement {
  id          String  @id @default(cuid())
  name        String
  description String
  icon        String?
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String

  earnedAt DateTime @default(now())

  @@index([userId])
  @@map("achievement")
}
